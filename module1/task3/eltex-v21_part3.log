cd ~
pwd
touch "${USER}_part3.log"
ls
mkdir -p D1/D2/D3
ls -R D1
touch D1/D2/file.txt
ls -l D1/D2
echo 'Задание 4' > D1/D2/file.txt
cat D1/D2/file.txt
ln -s ../file.txt D1/D2/D3/symlink_file.txt
ln D1/D2/file.txt D1/D2/D3/hardlink_file.txt
ls -li D1/D2 D1/D2/D3
mv D1/D2/file.txt D1/
ls -li D1 D1/D2 D1/D2/D3
cat D1/file.txt
cat D1/D2/D3/hardlink_file.txt
cat D1/D2/D3/symlink_file.txt
rm -r D1/D2
ls -l D1
find / -type f -size +20M 2>/dev/null > "${USER}_part3_gt20M.log"
cat "${USER}_part3_gt20M.log"
xargs -a "${USER}_part3_gt20M.log" du -h
find ~ -type f -mtime -1
which find
file /usr/bin/find
file /boot/initrd.img*
